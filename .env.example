# -----------------------------------------------------------------------------
# Assetto Corsa Server Pro - environment template
# Copy this file to .env and adjust values for your environment.
# -----------------------------------------------------------------------------

# Container / image
IMAGE_NAME=ghcr.io/falassio/assetto-corsa-server-pro:latest
CONTAINER_NAME=assetto-corsa-server

# Timezone used by logs and runtime
TZ=Europe/Rome

# Steam dedicated server app id (Assetto Corsa Dedicated Server)
STEAM_APP_ID=244210

# Internal installation path and binary name (usually no need to change)
AC_INSTALL_DIR=/opt/ac-server
AC_SERVER_BIN=acServer

# Optional arguments passed to the server binary
# Example: AC_SERVER_ARGS="-c"
AC_SERVER_ARGS=

# Steam update behavior
# STEAM_VALIDATE=1 enables file validation during update (safer, slower)
# SKIP_UPDATE=1 skips SteamCMD update at startup (faster restarts)
STEAMCMD_MAX_RETRIES=3
STEAMCMD_RETRY_DELAY=5
STEAM_VALIDATE=1
SKIP_UPDATE=0

# Host ports (left side in docker-compose port mappings)
AC_TCP_PORT=9600
AC_UDP_PORT=9600
HTTP_PORT=8081

# Control panel web port
CONTROL_PANEL_PORT=3000

# Control panel auth
AUTH_ENABLED=1
CONTROL_PANEL_USERNAME=admin
CONTROL_PANEL_PASSWORD=change-me-now
CONTROL_PANEL_ROLE=admin
# Optional multi-user JSON (overrides single-user vars)
# CONTROL_PANEL_USERS_JSON=[{"username":"admin","password":"strongpass","role":"admin"},{"username":"viewer","password":"viewerpass","role":"viewer"}]
CONTROL_PANEL_USERS_JSON=
CONTROL_PANEL_SESSION_SECRET=change-this-secret
CONTROL_PANEL_TOKEN_TTL_SEC=43200
CONTROL_PANEL_RATE_LIMIT_RPM=120
WEB_ORIGIN=*

# Control panel write and action behavior
ALLOW_CONFIG_WRITE=1
ACTION_MODE=mock
ACTION_TIMEOUT_MS=20000

# Set commands only when ACTION_MODE=command
# Example:
# ACTION_START_CMD=docker start assetto-corsa-server
# ACTION_STOP_CMD=docker stop assetto-corsa-server
# ACTION_RESTART_CMD=docker restart assetto-corsa-server
# ACTION_UPDATE_CMD=docker exec assetto-corsa-server /usr/local/bin/entrypoint.sh --update-only
# ACTION_BACKUP_CMD=tar -czf /data/backup-$(date +%Y%m%d%H%M%S).tgz /cfg /content /logs
ACTION_START_CMD=
ACTION_STOP_CMD=
ACTION_RESTART_CMD=
ACTION_UPDATE_CMD=
ACTION_BACKUP_CMD=
